<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Window/base theme. Compose (AquaCardTheme) drives all in-app theming. -->
    <style name="Theme.AquaCard" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
    <color name="app_background">#0E0F11</color>
</resources>
