# Normalize line endings on checkin
* text=auto eol=lf

# Windows-specific scripts keep CRLF
*.bat text eol=crlf

# Gradle wrapper script must stay LF + executable
gradlew text eol=lf

# Binary assets — never diff or normalize
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.jar binary
*.apk binary
*.aab binary
*.keystore binary
*.jks binary
